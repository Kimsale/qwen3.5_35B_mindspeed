+echo "开始训练 $(date '+%Y-%m-%d %H:%M:%S')"
+echo "=========================================="
+echo
+
+$TORCHRUN $DISTRIBUTED_ARGS posttrain_gpt.py \
+    $TUNE_ARGS \
+    $GPT_ARGS \
+    $DATA_ARGS \
+    $MOE_ARGS \
+    $OUTPUT_ARGS \
+    $OPTIMIZE_ARGS \
+    $TRAIN_ARGS \
+    $MODEL_PARALLEL_ARGS \
+    $EXTRA_ARGS \
+    --load ${CKPT_LOAD_DIR} \
+    --distributed-backend nccl \
+    --transformer-impl local \
+    2>&1 | tee "$LOG_FILE"
+
