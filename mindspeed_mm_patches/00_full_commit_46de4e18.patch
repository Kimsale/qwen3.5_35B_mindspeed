+#!/bin/bash
+# ============================================================
+# Qwen3-30B-A3B LoRA 微调 — Hulk 对齐配置
+# 基于 baseline，严格对齐 Hulk 训练参数（TP1/EP8/CP2/8192seq）
+# 改动清单：见文件末尾注释
+# ============================================================
+set -eo pipefail
+
