+    $GPT_ARGS \
+    $DATA_ARGS \
+    $MOE_ARGS \
+    $OUTPUT_ARGS \
+    $OPTIMIZE_ARGS \
+    $TRAIN_ARGS \
+    $MODEL_PARALLEL_ARGS \
+    $EXTRA_ARGS \
+    --load ${CKPT_LOAD_DIR} \
+    --distributed-backend nccl \
+    --transformer-impl local \
+    2>&1 | tee "$LOG_FILE"
+
+# ============================================================
+# 改动清单（相比基线 train_param.sh）
+# ============================================================
+# 1. 并行配置:
+#    - TP: 2 → 1
+#    - EP: 4 → 8
+#    - CP: 1 → 2 (新增 --context-parallel-size 2 --context-parallel-algo ulysses_cp_algo)
