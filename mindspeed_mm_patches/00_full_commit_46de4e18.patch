+  "$PERF_DIR/mbs2_fa2_fused_bucket64_chunk1024_80.yaml" \
+  1800 0.5 0
+
+run_one 6074 \
+  mbs2_fa2_fused_bucket64_chunk512_80 \
+  "$PERF_DIR/mbs2_fa2_fused_bucket64_chunk512_80.yaml" \
+  1800 0.5 0
+
+run_one 6075 \
