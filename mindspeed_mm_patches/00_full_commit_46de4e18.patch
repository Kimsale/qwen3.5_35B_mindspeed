+    --global-batch-size ${GBS:-16} \
+    --lr 5e-6 \
+    --lr-decay-style cosine \
+    --min-lr 1e-6 \
+    --weight-decay 1e-1 \
+    --lr-warmup-fraction 0.0 \
+    --attention-dropout 0.0 \
+    --init-method-std 0.01 \
+    --hidden-dropout 0.0 \
+    --clip-grad 5.0 \
+    --adam-beta1 0.9 \
+    --adam-beta2 0.95 \
+    --initial-loss-scale 4096 \
+    --seed 42 \
+    --bf16 \
+    --train-iters ${TRAIN_ITERS} \
+    --seq-length ${SEQ_LENGTH} \
+    --no-shared-storage
