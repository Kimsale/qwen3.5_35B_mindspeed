index 00000000..d3a08c52
--- /dev/null
+++ b/examples/qwen3_5_audio/qwen3_5_35B_audio_config.yaml
@@ -0,0 +1,177 @@
+# =============================================================================
+# Qwen3.5-35B-A3B + Whisper-large-v3 语音多模态 LoRA SFT 配置（FSDP2 栈）
+# 基于 examples/qwen3_5/qwen3_5_35B_config.yaml 改造：
+#   - model_id 改为 qwen3_5_audio（新增的语音多模态模型）
+#   - 新增 whisper_path / audio_token_id
+#   - template 改为 qwen2_omni（带 <|AUDIO|> 处理）
+#   - 冻结 visual + audio_tower(whisper)，LoRA 仅打在 language_model
+#   - projector 全量可训（不在 freeze 列表、也不靠 LoRA）
+# 占位路径用 <<...>> 标出，使用前请替换为真实路径。
+# =============================================================================
+
+# 并行策略
+parallel:
+  tensor_parallel_size: 1
+  fully_shard_parallel_size: auto
+  fsdp_plan:
+    apply_modules:
+      - model.language_model.layers.{*}.linear_attn
+      - model.language_model.layers.{*}.mlp
+      - model.language_model.layers.{*}
+      - model.language_model.embed_tokens
+      - model.language_model.norm
+      - model.language_model.rotary_emb
+      - model.language_model
+      - audio_tower
+      - audio_projector
+      - lm_head
+    hook_modules:
+      - model.language_model.layers.{*}
+    param_dtype: bf16
+    reduce_dtype: fp32
+  recompute: true
+  recompute_plan:
+      apply_modules:
+        - model.language_model.layers.{*}
+  ulysses_parallel_size: 1
+  expert_parallel_size: 1
+  ep_plan:
+    apply_modules:
+      - model.language_model.layers.{*}.mlp.experts
+
+### 数据相关配置
+data:
+  dataset_param:
+    dataset_type: huggingface
+    attr:
+      images: null
+      videos: null
+      audios: audios            # 数据 jsonl 中音频字段名
+      messages: messages
+      role_tag: role
+      content_tag: content
+      user_tag: user
+      assistant_tag: assistant
+
+    preprocess_parameters:
+      model_name_or_path: &HF_MODEL_LOAD_PATH /mnt/shared_data_196/sejin/models/Qwen3.5-35B-A3B
+      use_fast_tokenizer: true
+      split_special_tokens: false
+      audio_sampling_rate: 16000   # Whisper 固定 16kHz
+      # Qwen3.5 的 processor 是 vision-only(无 feature_extractor)，
+      # 指向 whisper 目录以挂上 mel 谱特征提取器，音频才能被处理。
+      audio_feature_extractor_path: /mnt/shared_data_196/sejin/models/whisper-large-v3
+
+    basic_parameters:
+      cutoff_len: 4096
+      template: qwen3_omni_nothink  # 正确模板：<audio>占位符→<|audio_start|><|audio_pad|>*N<|audio_end|>
+      train_on_prompt: false
+      mask_history: false
+      dataset_dir: ./data
+      dataset: &DATASET_PATH ./data/audio_sft_train.jsonl
+      cache_dir: ./cache_dir/
+      overwrite_cache: false
+      preprocessing_batch_size: 1000
+      preprocessing_num_workers: 8
+      max_samples: null
+
+  dataloader_param:
+    pin_memory: true
+    shuffle: true
+    dataloader_mode: sampler
+    drop_last: true
+    sampler_type: BaseRandomBatchSampler
+    num_workers: 8
+    collate_param:
+      model_name: qwen3vl          # DATA_COLLATOR 注册名，DataCollatorForQwen2vl 通用于所有模态
+      ignore_pad_token_for_loss: true
+
+# 模型配置
+model:
+  model_id: qwen3_5_audio          # ← 新增的语音多模态模型（在 plugin 目录注册）
+  model_name_or_path: *HF_MODEL_LOAD_PATH
+  trust_remote_code: true
+  attn_implementation: sdpa
+  # ---- audio 相关（由 overwrite_transformer_config 透传到 config）----
+  whisper_path: /mnt/shared_data_196/sejin/models/whisper-large-v3
+  audio_token_id: 248076           # <|audio_pad|> 的 token id
+  audio_projector_act: gelu
+  # ---- 冻结：视觉塔 + whisper encoder；projector 与 LoRA 可训 ----
+  freeze:
+    - model.visual
+    - audio_tower
+  loss_cfg:
+    loss_type: default
+    router_aux_loss_coef: 0.0
+  enable_chunk_loss: true
+  chunkloss_plan:
+    apply_module: lm_head
+    chunk_size: 1024
+  use_triton_gdn: true
+  use_grouped_expert_matmul: true
+
+# 训练配置
+training:
+  micro_batch_size: 1
+  gradient_accumulation_steps: 4   # 验证阶段调小,加快单步;占显存时再调大
+  seed: 42
+  lr: 1.0e-4                       # LoRA 微调常用较大 lr
+  lr_decay_style: cosine
+  lr_warmup_ratio: 0.03
+  weight_decay: 0.0
+  train_iters: 30                  # 端到端验证跑 30 步;跑通后再调大
+  clip_grad: 1.0
+  init_model_with_meta_device: true
+  optimizer: adamw
+  adam_fused: true
+  save_interval: 1000
+  no_load_optim: true
+  no_load_rng: true
+  no_save_optim: true
+  no_save_rng: true
+  load: /mnt/shared_data_196/sejin/models/Qwen3.5-35B-A3B-audio-dcp   # ← convert_weights.py 产出
+  save: ./save_path_qwen3_5_audio
+  use_deter_comp: false
+  # ---- LoRA：仅作用于 language_model 的注意力/MLP 线性层 ----
+  lora:
+    enable: true
+    rank: 16
+    alpha: 32
+    dropout: 0.05
+    init_lora_weights: kaiming
+    save_mode: lora_only
+    target_modules:
+      - model.language_model.layers.{*}.self_attn.q_proj
+      - model.language_model.layers.{*}.self_attn.k_proj
+      - model.language_model.layers.{*}.self_attn.v_proj
+      - model.language_model.layers.{*}.self_attn.o_proj
+  plugin:
+    - mindspeed_mm/fsdp/models/qwen3_5_audio          # ← 注册 qwen3_5_audio 模型
+    - mindspeed_mm/fsdp/data/datasets/huggingface
+
+# 工具配置
+tools:
+  profile:
+    enable: false
+    profile_type: static
+    ranks: [0]
+    static_param:
+      level: level1
+      with_stack: false
+      with_memory: false
+      record_shapes: false
+      with_cpu: true
+      save_path: ./profiling
+      start_step: 10
+      end_step: 11
+      data_simplification: false
+      aic_metrics_type: PipeUtilization
+  memory_profile:
+      enable: false
+      start_step: 1
+      end_step: 2
+      save_path: ./memory_snapshot
+      dump_ranks: [0]
+      stacks: all
+      max_entries: null
+      mem_info: false
