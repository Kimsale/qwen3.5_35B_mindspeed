@@ -0,0 +1,129 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+REPO_ROOT=${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}
+VENV=${VENV:-/data/sejin/env/venv_qwen35}
+CONFIG=${CONFIG:-examples/qwen3_5_audio/perf_tuning/ep8_mbs4_ga1_rc_off_pack_balanced_188.yaml}
+LOG_DIR=${LOG_DIR:-${REPO_ROOT}/logs}
+MASTER_PORT=${MASTER_PORT:-29665}
+NPU_SMI_INTERVAL=${NPU_SMI_INTERVAL:-10}
+
+export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH}
+
+cd "${REPO_ROOT}"
+set +u
+source /usr/local/Ascend/cann-8.5.0/set_env.sh
+source /usr/local/Ascend/nnal/atb/set_env.sh
+set -u
+
+export VIRTUAL_ENV="${VENV}"
+export PATH="${VENV}/bin:${PATH}"
+export PYTHONPATH="${REPO_ROOT}:${PYTHONPATH:-}"
+
+export NON_MEGATRON=true
+export MULTI_STREAM_MEMORY_REUSE=2
+export TASK_QUEUE_ENABLE=2
+export ASCEND_LAUNCH_BLOCKING=0
+export ACLNN_CACHE_LIMIT=100000
+export CPU_AFFINITY_CONF=1
+export PYTORCH_NPU_ALLOC_CONF=expandable_segments:True
+export HCCL_CONNECT_TIMEOUT=1800
+export TOKENIZERS_PARALLELISM=false
+export TORCH_DEVICE_BACKEND_AUTOLOAD=0
+export AUDIO_PLACEHOLDER='<|AUDIO|>'
+
+# Runtime-only WPS tuning. These do not change YAML hyperparameter definitions
+# or model structure.
+export PACK_DP_ALIGN=${PACK_DP_ALIGN:-1}
+export PACK_DP_ALIGN_TO=${PACK_DP_ALIGN_TO:-512}
+export PACK_DP_MIN_LEN=${PACK_DP_MIN_LEN:-2048}
+export PACK_DP_MAX_LEN=${PACK_DP_MAX_LEN:-2048}
+export PACK_DP_SKIP_MAX_RETRIES=${PACK_DP_SKIP_MAX_RETRIES:-256}
+export PACK_DP_SKIP_BATCH_ORDINALS=${PACK_DP_SKIP_BATCH_ORDINALS:-43}
+export PACK_DP_LOG_CANDIDATES=${PACK_DP_LOG_CANDIDATES:-0}
+export QWEN35_EP_DISPATCHER=${QWEN35_EP_DISPATCHER:-fused}
+export MOE_GMM_PAD_ENABLE=${MOE_GMM_PAD_ENABLE:-0}
+
+mkdir -p "${LOG_DIR}"
+stamp=$(date +%Y%m%d_%H%M%S)
+TRAIN_LOG="${LOG_DIR}/wps4000_8npu_${stamp}.log"
+MONITOR_LOG="${LOG_DIR}/npu_wps4000_8npu_${stamp}.log"
+
+monitor_pid=""
+cleanup() {
+    if [[ -n "${monitor_pid}" ]]; then
+        kill "${monitor_pid}" 2>/dev/null || true
+        wait "${monitor_pid}" 2>/dev/null || true
+    fi
+}
+trap cleanup EXIT
+
+(
+    while true; do
+        date +%s
+        npu-smi info
+        sleep "${NPU_SMI_INTERVAL}"
+    done
+) > "${MONITOR_LOG}" 2>&1 &
+monitor_pid=$!
+
+set +e
+"${VENV}/bin/torchrun" \
+    --nproc_per_node 8 \
+    --nnodes 1 \
+    --node_rank 0 \
+    --master_addr 127.0.0.1 \
+    --master_port "${MASTER_PORT}" \
+    mindspeed_mm/fsdp/train/trainer.py \
+    "${CONFIG}" \
+    > "${TRAIN_LOG}" 2>&1
+rc=$?
+set -e
+
+cleanup
+trap - EXIT
+
+python3 - "${TRAIN_LOG}" "${MONITOR_LOG}" <<'PY'
+import re
+import statistics
+import sys
+
+train_log, monitor_log = sys.argv[1:3]
+rows = []
+skips = []
+for line in open(train_log, errors="ignore"):
+    match = re.search(
+        r"iteration\s+(\d+)/\s*(\d+).*?elapsed time per iteration \(ms\): ([0-9.]+)"
+        r".*?tokens: input=(\d+).*?wps: input=([0-9.]+)",
+        line,
+    )
+    if match:
+        rows.append(
+            (
+                int(match.group(1)),
+                int(match.group(2)),
+                float(match.group(3)),
+                int(match.group(4)),
+                float(match.group(5)),
+            )
+        )
+    match = re.search(r"\[pack_dp_align\] skip batch candidate=(\d+) target_len=(\d+).*?skipped=(\d+)", line)
+    if match:
+        skips.append(tuple(map(int, match.groups())))
+
+print(f"train_log={train_log}")
+print(f"monitor_log={monitor_log}")
+if rows:
+    print(f"steps={len(rows)} last={rows[-1]}")
+    for skip in (0, 10, 20, 40):
+        values = [row[4] for row in rows if row[0] > skip]
+        if values:
+            print(
+                f"input_wps_skip_{skip}: n={len(values)} avg={sum(values) / len(values):.3f} "
+                f"median={statistics.median(values):.3f} min={min(values):.1f} max={max(values):.1f}"
+            )
+if skips:
+    print(f"pack_skips={skips}")
+PY
+
+exit "${rc}"
