+def _round_up_to_multiple(values: torch.Tensor, multiple: int) -> torch.Tensor:
+    if multiple <= 1:
+        return values
+    return ((values + multiple - 1) // multiple) * multiple
+
+
+def _moe_gmm_padded_counts(counts: torch.Tensor) -> torch.Tensor:
+    capacity = _env_int("MOE_GMM_PAD_CAPACITY", 0)
+    multiple = _env_int("MOE_GMM_PAD_MULTIPLE", 0)
+    min_capacity = _env_int("MOE_GMM_PAD_MIN_CAPACITY", 0)
+
+    padded_counts = counts
+    if multiple > 1:
+        padded_counts = _round_up_to_multiple(padded_counts, multiple)
+
+    if min_capacity > 0:
+        padded_counts = torch.maximum(
+            padded_counts,
+            torch.full_like(padded_counts, min_capacity),
+        )
+
+    if capacity > 0:
+        fixed_capacity = torch.full_like(counts, capacity)
+        overflow_counts = counts
+        if multiple > 1:
+            overflow_counts = _round_up_to_multiple(overflow_counts, multiple)
+        padded_counts = torch.where(counts <= capacity, fixed_capacity, overflow_counts)
+
+    return padded_counts
+
+
+def _pad_hidden_states_by_expert(hidden_states: torch.Tensor, group_list: torch.Tensor):
+    if not _env_bool("MOE_GMM_PAD_ENABLE", False):
+        return hidden_states, group_list, None
+
+    counts = group_list.to(dtype=torch.long)
+    padded_counts = _moe_gmm_padded_counts(counts)
+    if bool(torch.equal(counts, padded_counts)):
+        return hidden_states, group_list, None
+
+    num_tokens = hidden_states.shape[0]
+    num_padded_tokens = int(padded_counts.sum().item())
+    if num_padded_tokens <= num_tokens:
+        return hidden_states, group_list, None
+
+    real_offsets = torch.cumsum(counts, dim=0) - counts
+    padded_offsets = torch.cumsum(padded_counts, dim=0) - padded_counts
+    expert_ids = torch.arange(counts.numel(), dtype=torch.long, device=hidden_states.device)
+    expert_ids = torch.repeat_interleave(expert_ids, counts)
+    position_in_expert = torch.arange(num_tokens, dtype=torch.long, device=hidden_states.device) - real_offsets[expert_ids]
+    padded_indices = padded_offsets[expert_ids] + position_in_expert
+
+    padded_hidden_states = hidden_states.new_zeros((num_padded_tokens, hidden_states.shape[-1]))
+    padded_hidden_states.index_copy_(0, padded_indices, hidden_states)
+    return padded_hidden_states, padded_counts.to(device=group_list.device, dtype=group_list.dtype), padded_indices
+
