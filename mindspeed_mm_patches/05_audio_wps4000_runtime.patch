 from typing import Optional, Dict, Any
+import os
 import wave

 import torch
@@ -205,3 +206,78 @@ class LengthBucketBatchSampler(BaseRandomBatchSampler):
                 continue
             self.consumed_samples += self.micro_batch_times_data_parallel_size
             yield batch
+
+
+class BalancedLengthBucketBatchSampler(LengthBucketBatchSampler):
+    """
+    Length-bucketed sampler that balances each distributed global micro-batch by
+    the estimated token/audio length assigned to every rank.
+
+    This keeps pack-format local sequence lengths close across the DP group. FSDP2
+    still sees rank-aligned tensor shapes after the training-engine padding pass,
+    but the padding tail is kept small enough to preserve the pack-format gain.
+    """
+
+    def _balanced_rank_batches(self, global_batch):
+        sorted_indices = sorted(global_batch, key=lambda idx: self.lengths[idx], reverse=True)
+        rank_batches = [[] for _ in range(self.num_replicas)]
+        rank_sums = [0 for _ in range(self.num_replicas)]
+
+        for idx in sorted_indices:
+            candidates = [
+                rank for rank in range(self.num_replicas)
+                if len(rank_batches[rank]) < self.micro_batch_size
+            ]
+            rank = min(candidates, key=lambda item: (rank_sums[item], len(rank_batches[item]), item))
+            rank_batches[rank].append(idx)
+            rank_sums[rank] += self.lengths[idx]
+
+        return rank_batches
+
+    def _planned_rank_batches(self, global_batches):
+        plans = []
+        for order, global_batch in enumerate(global_batches):
+            rank_batches = self._balanced_rank_batches(global_batch)
+            rank_sums = [sum(self.lengths[idx] for idx in batch) for batch in rank_batches]
+            plans.append((order, rank_batches, max(rank_sums), sum(rank_sums)))
+
+        try:
+            max_rank_tokens = int(os.getenv("LENGTH_BUCKET_MAX_RANK_TOKENS", "0"))
+        except ValueError:
+            max_rank_tokens = 0
+        sort_desc = os.getenv("LENGTH_BUCKET_SORT_DESC", "0").lower() in ("1", "true", "yes", "on")
+
+        if max_rank_tokens > 0:
+            safe = [plan for plan in plans if plan[2] <= max_rank_tokens]
+            overflow = [plan for plan in plans if plan[2] > max_rank_tokens]
+            plans = safe + overflow
+
+        if sort_desc:
+            if max_rank_tokens > 0:
+                safe = [plan for plan in plans if plan[2] <= max_rank_tokens]
+                overflow = [plan for plan in plans if plan[2] > max_rank_tokens]
+                safe.sort(key=lambda plan: (plan[3], -plan[2], -plan[0]), reverse=True)
+                overflow.sort(key=lambda plan: (plan[3], -plan[2], -plan[0]), reverse=True)
+                plans = safe + overflow
+            else:
+                plans.sort(key=lambda plan: (plan[3], -plan[2], -plan[0]), reverse=True)
+
+        return [rank_batches for _, rank_batches, _, _ in plans]
+
+    def __iter__(self):
+        if self.next_consumed_samples is not None:
+            self.consumed_samples = self.next_consumed_samples
+            self.next_consumed_samples = None
+
+        active_total_samples = self.total_samples - self.last_batch_size
+        self.epoch = self.consumed_samples // active_total_samples
+        current_epoch_samples = self.consumed_samples % active_total_samples
+        batch_offset = current_epoch_samples // self.micro_batch_times_data_parallel_size
+
+        global_batches = self._planned_rank_batches(self._epoch_global_batches(active_total_samples))
+        for rank_batches in global_batches[batch_offset:]:
+            batch = rank_batches[self.rank]
+            if len(batch) != self.micro_batch_size:
+                continue
+            self.consumed_samples += self.micro_batch_times_data_parallel_size
+            yield batch
